# ──────────────────────────────────────────────────────────────────────────────
# apps/api/.env.example
# Copy to apps/api/.env and fill in real values.
# NEVER commit .env to git — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required — startup refuses to boot if any of these are missing ────────────

# At least 32 characters of random entropy.
# Generate with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ud_transport

# MinIO / S3-compatible object store credentials
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_SECRET_KEY

# Public base URL used to build presigned URLs returned to the browser.
# In dev this is the MinIO address; in prod use your CDN / public endpoint.
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Allowed CORS origin for the Next.js frontend
FRONTEND_URL=http://localhost:3000

# ── Optional — defaults shown ─────────────────────────────────────────────────

PORT=3001

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=ud-transport

# Copy to .env for local dev. In Railway, set these as service variables instead
# (never commit a real .env — see .dockerignore / root CLAUDE.md).

# ── Required everywhere (enforced by src/config/validate-env.ts) ────────────

# Min 32 random characters. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# postgresql://user:password@host:5432/dbname
# In Railway: use the Postgres service's PUBLIC connection string when running
# db:push / db:manual-migrations / db:seed from your laptop; the API service
# itself should use the INTERNAL (*.railway.internal) URL for lower latency.
DATABASE_URL=postgresql://postgres:password@localhost:5432/ud_transport

MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key

# Public base URL used to build presigned upload/download URLs returned to
# clients (browsers/phones) — must be reachable from OUTSIDE the Railway
# network, not the *.railway.internal hostname.
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# The web app's origin, used for CORS (app.enableCors in main.ts).
FRONTEND_URL=http://localhost:3000

# ── MinIO connection (each has a silent-fallback default if unset — set all ─
# ── three explicitly in every real environment, don't rely on the defaults) ─

# Host MinIO's S3 API listens on. PRODUCTION-REQUIRED: must be MinIO's PUBLIC
# Railway domain (e.g. minio-production-xxxx.up.railway.app), never
# *.railway.internal — presigned URLs are signed against this host, and a
# phone on the public internet cannot resolve an internal Railway hostname.
# Defaults to "localhost" if unset.
MINIO_ENDPOINT=localhost

# PRODUCTION-REQUIRED: must be 443 when MINIO_USE_SSL=true (Railway serves the
# public domain over HTTPS on 443, regardless of MinIO's internal port).
# Defaults to 9000 if unset.
MINIO_PORT=9000

# PRODUCTION-REQUIRED: must be "true" in every deployed environment — the
# public Railway domain is HTTPS-only. Defaults to false (plain HTTP) if unset.
MINIO_USE_SSL=false

# Defaults to "ud-transport" if unset. Must already exist in MinIO before
# first upload (bucket creation is not automatic) — see README's Railway
# deploy section.
MINIO_BUCKET=ud-transport

# ── Environment gating ───────────────────────────────────────────────────────

# Unset (or anything other than "production") = staging/dev behavior:
# PROXIMITY_BYPASS is honored if also set. Set to "production" to structurally
# disable PROXIMITY_BYPASS (validate-env.ts refuses to boot if both are set).
APP_ENV=

# Dev/staging-only escape hatch for the mobile geolocation gate. Must never be
# "true" when APP_ENV=production — the app will refuse to start rather than
# silently ignore it.
PROXIMITY_BYPASS=false

# Optional, defaults to 3001.
PORT=3001

apps/web/.env.example:
# Copy to .env.local for local dev. In Railway, these must be set as Docker
# BUILD ARGS on the web service (Next.js inlines NEXT_PUBLIC_* at build time —
# a runtime-only env var is silently ignored and the image falls back to
# http://localhost:3001, see lib/api.ts).

# The API's public HTTPS URL. Required as a build arg in every deployed
# environment.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dev/staging-only escape hatch that skips the client-side geolocation prompt
# in the audit checklist flow (lib/geolocation.ts, apps/web CLAUDE.md). Should
# match the API's PROXIMITY_BYPASS setting for the same environment — if the
# API bypasses proximity but the web build doesn't set this too, the client
# still attempts real GPS acquisition even though the server doesn't need it.
# Must be unset/false in production builds.
NEXT_PUBLIC_PROXIMITY_BYPASS=false